---
import '../styles/global.css';
import TerminalPane from "../components/TerminalPane.svelte";
import ContentPane from "../components/ContentPane.svelte";

---
<!DOCTYPE html>
<html lang="en" class="h-full">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Welcome to the Sunny Side!</title>
    <link rel="icon" href="/favicon.ico" />
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-FDGES615HV"></script>
        <script>
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());
        gtag('config', 'G-FDGES615HV');
        </script>
</head>
  <body class="h-full">
    <div class="h-screen w-screen grid grid-cols-1 md:grid-cols-[1fr_auto] md:grid-rows-1">
      <!-- Content -->
      <main class="overflow-y-auto overflow-x-hidden bg-surface text-text transition-colors duration-150 ease-retro">
        <ContentPane client:load />
      </main>

      <!-- Terminal (desktop only) -->
      <aside class="hidden md:block">
        <TerminalPane client:load />
      </aside>
    </div>
  </body>
</html>
